---
interface Props {
  consultationType: string;
  allocatedMinutes: number;
}

const { consultationType, allocatedMinutes } = Astro.props;

// Replicated collection layout simulating availability matrix queries calculated at edge runtime
const activeAvailableSlots = [
  { timeDisplay: '09:00 GMT', isoString: '2026-06-05T09:00:00Z' },
  { timeDisplay: '11:30 GMT', isoString: '2026-06-05T11:30:00Z' },
  { timeDisplay: '14:00 GMT', isoString: '2026-06-05T14:00:00Z' },
  { timeDisplay: '16:15 GMT', isoString: '2026-06-05T16:15:00Z' },
];
---

<div class="bg-brand-surface/60 border border-slate-800 rounded-2xl p-6 backdrop-blur-xl shadow-2xl max-w-md mx-auto">
  <div class="flex justify-between items-center border-b border-slate-800/80 pb-4 mb-6">
    <div>
      <h3 class="text-lg font-bold text-white tracking-tight">{consultationType}</h3>
      <p class="text-xs text-slate-400 mt-0.5">JS Office Solutions Hub</p>
    </div>
    <span class="bg-violet-950/80 text-brand-accent border border-violet-800/50 text-xs font-mono font-bold px-2.5 py-1 rounded-md">
      {allocatedMinutes} MINS
    </span>
  </div>

  <div class="space-y-3">
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Select Available Consultation Window</p>
    <div class="grid grid-cols-2 gap-2.5">
      {activeAvailableSlots.map((slot) => (
        <button
          data-iso={slot.isoString}
          class="py-3 px-4 bg-brand-canvas border border-slate-800 rounded-xl text-xs font-medium text-slate-300 transition-all duration-200 hover:border-brand-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-brand-accent/40 group flex items-center justify-between"
        >
          <span>{slot.timeDisplay}</span>
          <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-150 text-brand-accent font-bold">&rarr;</span>
        </button>
      ))}
    </div>
  </div>

  <div class="mt-6 pt-4 border-t border-slate-800/50">
    <p class="text-[10px] text-slate-500 leading-normal">
      Data architectures managed in accordance with the laws of England & Wales. Regulatory Oversight: Joshua Stevens (DPO).
    </p>
  </div>
</div>
