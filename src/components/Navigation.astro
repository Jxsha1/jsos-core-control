---
// Query the active URL pathname to apply dynamic visual focus states to navigation links
const { pathname } = Astro.url;

const navItems = [
  { href: '/dashboard/sales', label: 'Sales Tracker' },
  { href: '/dashboard/clients', label: 'CRM & Onboarding' },
  { href: '/dashboard/tickets', label: 'PSA Ticketing' },
  { href: '/dashboard/invoices', label: 'Invoice Generator' },
];

const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---

<nav class="sticky top-0 z-50 w-full border-b border-slate-900 bg-brand-canvas/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      
      <a href="/dashboard/sales" class="flex items-center gap-3 group">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-primary to-brand-accent shadow-md shadow-brand-primary/10 group-hover:shadow-brand-primary/30 transition-all duration-300">
          <span class="text-sm font-bold text-white tracking-wider">JS</span>
        </div>
        <span class="text-sm font-extrabold tracking-tight text-white uppercase">
          Core <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Control</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {navItems.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-xl text-xs font-semibold tracking-wide transition-all duration-200 ${
                active 
                  ? 'bg-brand-surface text-brand-accent border border-brand-primary/30' 
                  : 'text-slate-400 hover:text-white hover:bg-brand-surface/40'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </div>

      <div class="flex items-center gap-2">
        <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest hidden sm:inline">
          DPO Secure: J. Stevens
        </span>
      </div>

    </div>
  </div>
</nav>
