---
import Layout from '../layouts/Layout.astro';

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const password = formData.get("password")?.toString();
    
    // Retrieves the master password from Cloudflare environment configuration variables
    const masterPassword = Astro.locals.runtime.env.ADMIN_PASSWORD || "JSOS_Secure_2026";
    
    if (password === masterPassword) {
      const sessionToken = crypto.randomUUID();
      const kv = Astro.locals.runtime.env.SESSION;
      
      // Store session allocation markers within the Cloudflare KV namespace with an 8-hour expiry time (28800 seconds)
      await kv.put(sessionToken, JSON.stringify({ authenticated: true, createdAt: new Date().toISOString() }), {
        expirationTtl: 28800
      });
      
      // Assign the secure verification cookie across the entire domain scope
      Astro.cookies.set('jsos_session', sessionToken, {
        path: '/',
        httpOnly: true,
        secure: true,
        sameSite: 'strict',
        maxAge: 28800
      });
      
      return Astro.redirect('/dashboard/sales');
    } else {
      errorMessage = "Invalid administrative access credentials.";
    }
  } catch (error: any) {
    errorMessage = `Authentication subsystem error: ${error.message}`;
  }
}
---

<Layout title="Administrative Login | JSOS Core Control" hideNav={true}>
  <main class="min-h-screen bg-brand-canvas flex flex-col items-center justify-center p-4">
    <div class="w-full max-w-md bg-brand-surface/70 border border-slate-800 p-8 rounded-2xl backdrop-blur-xl shadow-2xl space-y-6">
      
      <div class="flex flex-col items-center text-center space-y-2">
        <img src="/jsos_logo.svg" alt="JS Office Solutions Logo" class="h-12 w-auto object-contain" />
        <h2 class="text-xl font-bold text-white tracking-tight pt-2">Core Control Access</h2>
        <p class="text-xs text-slate-400">Unauthorised access monitoring is active under the jurisdiction of England & Wales.</p>
      </div>

      {errorMessage && (
        <div class="p-4 bg-rose-500/10 border border-rose-500/20 text-rose-400 rounded-xl text-xs font-semibold font-mono text-center">
          {errorMessage}
        </div>
      )}

      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1.5">Administrative Password</label>
          <input 
            type="password" 
            name="password" 
            required 
            class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-3 text-xs text-white focus:outline-none focus:border-brand-primary tracking-widest font-mono"
            placeholder="••••••••••••••••"
          />
        </div>

        <button 
          type="submit" 
          class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-3 rounded-xl transition tracking-wide uppercase font-mono"
        >
          Verify Credentials & Enter
        </button>
      </form>
      
    </div>
  </main>
</Layout>
