---
import Layout from '../layouts/Layout.astro';
---
<Layout title="JSOS Core Control | Edge Hub" hideNav={true}>
  <main class="flex flex-col items-center justify-center min-h-screen px-4 selection:bg-brand-primary/40">
    <div class="text-center space-y-6 max-w-xl">
      
      <div class="inline-flex items-center justify-center">
        <img src="/jsos_logo.svg" alt="JS Office Solutions Logo" class="h-12 w-auto object-contain" />
      </div>
      
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        JSOS <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Core Control</span>
      </h1>
      
      <p class="text-slate-400 text-sm md:text-base leading-relaxed max-w-md mx-auto">
        Serverless Operations Hub running on the Cloudflare distributed edge network layer. Custom CRM, Booking matrix, Sales Tracker, and Automated Billing pipelines.
      </p>
      
      <div class="pt-4">
        <a 
          href="/dashboard/sales" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs rounded-xl transition-all duration-200 shadow-lg shadow-brand-primary/20 group hover:scale-[1.02]"
        >
          <span>Enter Control Console</span>
          <span class="transition-transform duration-150 group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>

      <div class="pt-6 flex items-center justify-center gap-4 text-[10px] font-mono text-slate-600 border-t border-slate-950 max-w-xs mx-auto">
        <span>Jurisdiction: England & Wales</span>
        <span class="w-1 h-1 rounded-full bg-slate-800"></span>
        <span>Astro v5 Production</span>
      </div>
      
    </div>
  </main>
</Layout>
