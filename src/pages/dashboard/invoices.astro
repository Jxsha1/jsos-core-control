---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
const r2 = Astro.locals.runtime.env.INVOICE_VAULT;
let feedbackMessage = "";

const viewMode = Astro.url.searchParams.get('view') || 'active';
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create") {
      const clientId = formData.get("clientId");
      const opportunityId = formData.get("opportunityId"); // Maps choice directly from internal project matrix
      const prefix = formData.get("prefix"); 
      const description = formData.get("itemDescription");
      const costRaw = formData.get("itemCost");

      if (clientId && prefix && description && costRaw) {
        const cost = parseFloat(costRaw.toString());
        
        // 1. Calculate Target Abbreviation Map Rules (4 chars if single word, initials if multi word)
        const client = await db.prepare("SELECT company_name FROM clients WHERE id = ?").bind(clientId).first();
        if (!client) throw new Error("Target client profile mismatch.");
        
        const name = client.company_name.trim();
        const words = name.split(/\s+/);
        let abbreviation = (words.length === 1) ? name.substring(0, 4).toUpperCase() : words.map((w: string) => w[0]).join("").toUpperCase();

        // 2. Scan Sequential Matrix Row Total Counts to Determine Next Incremental Identification ID Number
        const counterScan = await db.prepare("SELECT COUNT(*) as count FROM invoices").first();
        const nextSequenceId = (counterScan?.count || 0) + 1;

        const generatedInvoiceNumber = `${prefix}-${abbreviation}-${nextSequenceId}`;

        const issuedStr = new Date().toISOString().split('T')[0];
        const due = new Date(); due.setDate(due.getDate() + 14);
        const dueStr = due.toISOString().split('T')[0];
        
        const invoiceId = crypto.randomUUID();
        const r2Key = `archives/${invoiceId}.json`;

        const payload = { id: invoiceId, invoiceNumber: generatedInvoiceNumber, total: cost, breakdown: description };
        await r2.put(r2Key, JSON.stringify(payload, null, 2), { contentType: 'application/json' });

        // 3. TRANSACTION COUPLING STEP: Log Invoice and instantly shift parent Opportunity to Contract Won status stage parameters
        await db.prepare(`
          INSERT INTO invoices (id, client_id, opportunity_id, invoice_number, amount_due, currency, status, issued_date, due_date, r2_archive_url, is_archived)
          VALUES (?, ?, ?, ?, ?, 'Sent', ?, ?, ?, 0)
        `).bind(invoiceId, clientId, opportunityId || null, generatedInvoiceNumber, cost, issuedStr, dueStr, `/vault/${invoiceId}`).run();

        // Automated Link execution routine: If tied to a specific project tracker, update its database stage immediately
        if (opportunityId) {
          await db.prepare("UPDATE opportunities SET stage = 'Contract Won' WHERE id = ?").bind(opportunityId).run();
          feedbackMessage = `Success: Invoice ${generatedInvoiceNumber} compiled. Connected sales project automatically advanced to Contract Won!`;
        } else {
          feedbackMessage = `Success: Independent invoice compiled reference name: ${generatedInvoiceNumber}`;
        }
      }
    }

    if (action === "update") {
      const id = formData.get("itemId");
      const costRaw = formData.get("itemCost");
      const status = formData.get("status");

      await db.prepare(`
        UPDATE invoices SET amount_due = ?, status = ? WHERE id = ?
      `).bind(parseFloat(costRaw.toString()), status, id).run();
      feedbackMessage = "Success: Invoice row adjustments committed inline.";
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 1 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Transaction relocated to archives.";
    }

    if (action === "restore") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 0 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Transaction restored to ledger dashboards.";
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM invoices WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Row purged securely from distributed arrays.";
    }
  } catch (err: any) {
    feedbackMessage = `Ledger Processing Fault: ${err.message}`;
  }
}

// Read current active data variables mapping directly from edge instances
const invoicesList = (await db.prepare(`
  SELECT i.*, c.company_name, o.title as project_title FROM invoices i 
  JOIN clients c ON i.client_id = c.id 
  LEFT JOIN opportunities o ON i.opportunity_id = o.id
  WHERE i.is_archived = ? ORDER BY i.issued_date DESC
`).bind(viewMode === 'archived' ? 1 : 0).all()).results || [];

const clientsList = (await db.prepare("SELECT id, company_name FROM clients WHERE is_archived = 0 ORDER BY company_name ASC").all()).results || [];
const activeOpportunitiesList = (await db.prepare("SELECT id, title, client_id FROM opportunities WHERE is_archived = 0 AND stage != 'Contract Won'").all()).results || [];
---

<Layout title="Invoice Generator & Vault Ledger | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-6 md:p-12 space-y-10">
    
    <div class="flex justify-between items-end border-b border-slate-800 pb-6">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Automated Ledger Interconnect</span>
        <h1 class="text-3xl font-extrabold text-white tracking-tight mt-1">Invoice Generation Hub</h1>
      </div>
      <div class="flex gap-2 font-mono text-xs">
        <a href="?view=active" class={`px-4 py-2 rounded-xl border font-bold transition ${viewMode === 'active' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Active Balances</a>
        <a href="?view=archived" class={`px-4 py-2 rounded-xl border font-bold transition ${viewMode === 'archived' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Archived Vault</a>
      </div>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-2xl p-6 shadow-xl h-fit">
        <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider mb-4">Compile Financial Ledger</h3>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="actionType" value="create" />
          
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Client Debtor *</label>
            <select name="clientId" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2 text-xs text-white">
              <option value="">Select Company Account</option>
              {clientsList.map((c: any) => <option value={c.id}>{c.company_name}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Link to Sales Tracker Project (Triggers "Contract Won")</label>
            <select name="opportunityId" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2 text-xs text-brand-accent font-mono">
              <option value="">Independent / Standalone Billable Item</option>
              {activeOpportunitiesList.map((o: any) => <option value={o.id}>[{o.title}]</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Alphanumeric Code Prefix *</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JLDS</span> <input type="radio" name="prefix" value="JLDS" checked required class="accent-brand-accent" />
              </label>
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JJS</span> <input type="radio" name="prefix" value="JJS" class="accent-brand-accent" />
              </label>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Billable Milestone Work Summary *</label>
            <input type="text" name="itemDescription" required placeholder="e.g. Infrastructure Deployment" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2 text-xs text-white" />
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Gross Net Cost Capital (£) *</label>
            <input type="number" name="itemCost" step="0.01" required placeholder="0.00" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2 text-xs text-white" />
          </div>

          <button type="submit" class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-3 rounded-xl transition font-mono tracking-wide">
            Generate & Archive Invoice
          </button>
        </form>
      </div>

      <div class="xl:col-span-3">
        <div class="overflow-x-auto border border-slate-800 rounded-2xl bg-brand-surface/30 shadow-2xl">
          <table class="min-w-full divide-y divide-slate-800 text-left">
            <thead class="bg-brand-surface text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">
              <tr>
                <th class="px-6 py-4">Invoice Reference Name</th>
                <th class="px-6 py-4">Linked Project Context</th>
                <th class="px-6 py-4">Corporate Debtor Entity</th>
                <th class="px-6 py-4">Lifecycle Timelines</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4">Net Capital Amount</th>
                <th class="px-6 py-4 text-right">Console Controls</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/60 text-xs text-slate-300">
              {invoicesList.map((invoice: any) => {
                const isEditing = editTargetId === invoice.id;
                const formId = `form-invoice-${invoice.id}`;

                return (
                  <tr class="hover:bg-slate-900/40 transition-colors duration-150">
                    {isEditing && (
                      <form method="POST" id={formId}>
                        <input type="hidden" name="actionType" value="update" />
                        <input type="hidden" name="itemId" value={invoice.id} />
                      </form>
                    )}

                    <td class="px-6 py-4 font-mono font-bold text-brand-accent tracking-wide">{invoice.invoice_number}</td>
                    
                    <td class="px-6 py-4 font-mono text-xs text-slate-400">
                      {invoice.project_title ? `💼 ${invoice.project_title}` : <span class="text-slate-600">Standalone Item</span>}
                    </td>

                    <td class="px-6 py-4 font-bold text-white">{invoice.company_name}</td>

                    <td class="px-6 py-4 font-mono text-[11px] text-slate-500">
                      <div>Issued: {new Date(invoice.issued_date).toLocaleDateString('en-GB')}</div>
                      <div class="text-brand-accent font-semibold mt-0.5">Due: {new Date(invoice.due_date).toLocaleDateString('en-GB')}</div>
                    </td>

                    <td class="px-6 py-4">
                      {isEditing ? (
                        <select name="status" form={formId} class="bg-brand-canvas border border-slate-800 rounded px-1 py-0.5 text-xs text-white">
                          <option value="Draft" selected={invoice.status === 'Draft'}>Draft</option>
                          <option value="Sent" selected={invoice.status === 'Sent'}>Sent</option>
                          <option value="Paid" selected={invoice.status === 'Paid'}>Paid</option>
                          <option value="Overdue" selected={invoice.status === 'Overdue'}>Overdue</option>
                        </select>
                      ) : (
                        <span class={`text-[9px] font-mono font-bold px-2 py-0.5 rounded border ${invoice.status === 'Paid' ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' : 'bg-amber-500/10 border-amber-500/30 text-amber-400'}`}>
                          {invoice.status}
                        </span>
                      )}
                    </td>

                    <td class="px-6 py-4 font-mono font-bold text-white">
                      {isEditing ? (
                        <input type="number" name="itemCost" step="0.01" value={invoice.amount_due} form={formId} required class="bg-brand-canvas border border-slate-800 rounded px-2 py-1 text-xs text-white w-20" />
                      ) : (
                        <span>£{invoice.amount_due.toLocaleString('en-GB', { minimumFractionDigits: 2 })}</span>
                      )}
                    </td>

                    <td class="px-6 py-4 text-right space-x-2 whitespace-nowrap font-mono text-[11px]">
                      {isEditing ? (
                        <>
                          <button type="submit" form={formId} class="text-emerald-400 hover:underline font-bold">Save</button>
                          <span class="text-slate-800">|</span>
                          <a href="?" class="text-slate-500 hover:underline">Cancel</a>
                        </>
                      ) : viewMode === 'active' ? (
                        <>
                          <a href={`?editId=${invoice.id}`} class="text-brand-accent hover:underline">Edit</a>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="archive" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-amber-500 hover:underline">Archive</button>
                          </form>
                        </>
                      ) : (
                        <>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="restore" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-emerald-400 hover:underline">Restore</button>
                          </form>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline" onsubmit="return confirm('PERMANENT LEDGER WIPEOUT AUDIT: Destroy financial node record?');">
                            <input type="hidden" name="actionType" value="purge" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-rose-500 hover:underline font-bold">Secure Purge</button>
                          </form>
                        </>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</Layout>
