---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
const r2 = Astro.locals.runtime.env.INVOICE_VAULT;
let feedbackMessage = "";
const viewMode = Astro.url.searchParams.get('view') || 'active';
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create") {
      const clientId = formData.get("clientId");
      const opportunityId = formData.get("opportunityId");
      const prefix = formData.get("prefix"); 
      const lineItemsRaw = formData.get("lineItems")?.toString() || "[]";
      
      let lineItems = [];
      try {
        lineItems = JSON.parse(lineItemsRaw);
      } catch (e) {
        lineItems = [];
      }

      let flatFeeAmount = 0;
      let recurringAmount = 0;
      let isFlatFee = 0;
      let isRecurring = 0;
      let recurringInterval = null;

      lineItems.forEach((item: any) => {
        if (item.type === "Flat Fee") {
          flatFeeAmount += parseFloat(item.amount || "0");
          isFlatFee = 1;
        } else if (item.type === "Recurring Fee") {
          recurringAmount += parseFloat(item.amount || "0");
          isRecurring = 1;
          recurringInterval = item.interval || "Monthly";
        }
      });

      const totalCombinedCost = flatFeeAmount + recurringAmount;

      if (clientId && prefix && lineItems.length > 0 && totalCombinedCost > 0) {
        const client = await db.prepare("SELECT company_name, email FROM clients WHERE id = ?").bind(clientId).first();
        if (!client) throw new Error("Target account error.");
        
        const name = client.company_name.trim();
        const words = name.split(/\s+/);
        let abbreviation = (words.length === 1) ? name.substring(0, 4).toUpperCase() : words.map((w: string) => w[0]).join("").toUpperCase();
        const counterScan = await db.prepare("SELECT COUNT(*) as count FROM invoices").first();
        const nextSequenceId = (counterScan?.count || 0) + 1;
        const generatedInvoiceNumber = `${prefix}-${abbreviation}-${nextSequenceId}`;

        const issuedStr = new Date().toISOString().split('T')[0];
        const due = new Date(); due.setDate(due.getDate() + 14);
        const dueStr = due.toISOString().split('T')[0];
        const invoiceId = crypto.randomUUID();

        await db.prepare(`
          INSERT INTO invoices (
            id, client_id, opportunity_id, invoice_number, item_description, 
            is_flat_fee, flat_fee_amount, is_recurring, recurring_interval, 
            recurring_amount, amount_due, status, issued_date, due_date, is_archived
          ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        `).bind(
          invoiceId, clientId, opportunityId || null, generatedInvoiceNumber, lineItemsRaw, 
          isFlatFee, flatFeeAmount, isRecurring, recurringInterval, recurringAmount, 
          totalCombinedCost, 'Generated', issuedStr, dueStr, 0
        ).run();

        const emailBinding = Astro.locals.runtime.env.EMAIL;
        if (emailBinding) {
          try {
            await emailBinding.send({
              to: [{ email: client.email, name: client.company_name }],
              from: { email: "billing@jsos.uk", name: "JS Office Solutions Billing" },
              subject: `Invoice Generated: ${generatedInvoiceNumber}`,
              text: `Hello,\n\nA new structured invoice statement has been generated for your account.\n\nInvoice Number: ${generatedInvoiceNumber}\nAmount Due: £${totalCombinedCost.toLocaleString('en-GB', {minimumFractionDigits:2})}\n\nThank you for your business.`
            });
          } catch (mailError) {
            console.error(mailError);
          }
        }

        feedbackMessage = `Success: Invoice ${generatedInvoiceNumber} compiled safely.`;
      }
    }

    if (action === "update") {
      const id = formData.get("itemId");
      const nextStatus = formData.get("status");
      const cost = parseFloat(formData.get("amountDue")?.toString() || "0");

      await db.prepare(`
        UPDATE invoices SET status = ?, amount_due = ? WHERE id = ?
      `).bind(nextStatus, cost, id).run();

      return Astro.redirect(`/dashboard/invoices?view=${viewMode}`);
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 1 WHERE id = ?").bind(id).run();
    }

    if (action === "restore") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 0 WHERE id = ?").bind(id).run();
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM invoices WHERE id = ?").bind(id).run();
    }
  } catch (err: any) {
    feedbackMessage = `Exception Event: ${err.message}`;
  }
}

const invoicesList = (await db.prepare(`
  SELECT i.*, c.company_name, o.title as project_title FROM invoices i 
  JOIN clients c ON i.client_id = c.id 
  LEFT JOIN opportunities o ON i.opportunity_id = o.id
  WHERE i.is_archived = ? ORDER BY i.issued_date DESC
`).bind(viewMode === 'archived' ? 1 : 0).all()).results || [];

const clientsList = (await db.prepare("SELECT id, company_name FROM clients WHERE is_archived = 0 ORDER BY company_name ASC").all()).results || [];
const activeOpportunitiesList = (await db.prepare("SELECT id, title FROM opportunities WHERE is_archived = 0 AND stage != 'Contract Won'").all()).results || [];
const visualProgressionSteps = [{ key: 'Generated', label: 'Generated' }, { key: 'Sent', label: 'Sent' }, { key: 'Paid', label: 'Paid' }];
---

<Layout title="Invoice Generator & Vault Ledger | JSOS Core Control">
  <style is:global>
    @media print {
      .no-print {
        display: none !important;
      }
      #previewModal {
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        width: 100% !important;
        height: auto !important;
        background: #ffffff !important;
        display: block !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      body > *:not(#previewModal) {
        display: none !important;
      }
      .print-modal-box {
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
        background: #ffffff !important;
        width: 100% !important;
        max-width: 100% !important;
      }
      .print-layout-target {
        display: block !important;
        background: #ffffff !important;
        color: #0f172a !important;
        padding: 0 !important;
        width: 100% !important;
      }
      .print-layout-target * {
        color: #0f172a !important;
        background: transparent !important;
        border-color: #cbd5e1 !important;
      }
      .print-text-primary {
        color: #6d28d9 !important;
      }
    }
  </style>

  <main class="max-w-7xl mx-auto p-4 md:p-6 space-y-6 w-full box-border overflow-hidden no-print">
    
    <div class="flex justify-between items-end border-b border-slate-800 pb-4 flex-wrap gap-4">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Automated Ledger</span>
        <h1 class="text-2xl font-extrabold text-white tracking-tight mt-1">Invoice Generation</h1>
      </div>
      <div class="flex gap-2 font-mono text-xs">
        <a href="?view=active" class={`px-3 py-1.5 rounded-lg border transition ${viewMode === 'active' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Active</a>
        <a href="?view=archived" class={`px-3 py-1.5 rounded-lg border transition ${viewMode === 'archived' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Archived</a>
      </div>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 items-start w-full">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-xl p-5 shadow-xl space-y-4 w-full box-border">
        <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider">Compile Financial Ledger</h3>
        <form method="POST" id="mainInvoiceGenerationForm" class="space-y-3">
          <input type="hidden" name="actionType" value="create" />
          
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Client *</label>
            <select name="clientId" required class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-2 text-xs text-white focus:outline-none">
              <option value="">Select Account</option>
              {clientsList.map((c: any) => <option value={c.id}>{c.company_name}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Link to Sales Project</label>
            <select name="opportunityId" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-2 text-xs text-brand-accent font-mono focus:outline-none">
              <option value="">Independent Milestone Item</option>
              {activeOpportunitiesList.map((o: any) => <option value={o.id}>{o.title}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Prefix Code *</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JLDS</span> <input type="radio" name="prefix" value="JLDS" checked required />
              </label>
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JJS</span> <input type="radio" name="prefix" value="JJS" />
              </label>
            </div>
          </div>

          <div class="border border-slate-800 p-3 rounded-xl bg-brand-canvas/30 space-y-3">
            <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide">Work Items Manifest Builder</span>
            
            <div class="space-y-2">
              <input type="text" id="tempItemDescription" placeholder="Description (e.g. Website Rebuild)" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none" />
              
              <div class="grid grid-cols-2 gap-2">
                <select id="tempItemType" class="bg-brand-canvas border border-slate-800 rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none" onchange="document.getElementById('tempIntervalContainer').style.display = this.value === 'Recurring Fee' ? 'block' : 'none'">
                  <option value="Flat Fee">Flat Fee</option>
                  <option value="Recurring Fee">Recurring Fee</option>
                </select>
                
                <div id="tempIntervalContainer" style="display: none;">
                  <select id="tempItemInterval" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none">
                    <option value="Weekly">Weekly</option>
                    <option value="Monthly" selected>Monthly</option>
                    <option value="Yearly">Yearly</option>
                  </select>
                </div>
              </div>
              
              <input type="number" id="tempItemAmount" step="0.01" placeholder="Amount (£)" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none" />
              
              <button type="button" onclick="window.append_item_to_stack()" class="w-full bg-brand-surface border border-slate-700 hover:border-brand-accent text-brand-accent font-bold text-[10px] py-1.5 rounded-lg transition font-mono uppercase tracking-wider">
                + Append Item Element
              </button>
            </div>

            <div id="stagedItemsManifestQueue" class="space-y-1.5 max-h-36 overflow-y-auto pt-2 border-t border-slate-800/40 empty:hidden"></div>
            <input type="hidden" id="lineItemsSerializedInput" name="lineItems" value="[]" required />
          </div>

          <button type="submit" class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-2 rounded-lg transition font-mono uppercase tracking-wider">
            Execute Statement Log
          </button>
        </form>
      </div>

      <div class="xl:col-span-3 space-y-4 w-full overflow-hidden">
        <div class="border border-slate-800 rounded-xl bg-brand-surface/30 shadow-2xl w-full overflow-hidden">
          <table class="w-full min-w-full divide-y divide-slate-800 text-left table-fixed border-collapse">
            <thead class="bg-brand-surface text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">
              <tr>
                <th class="px-3 py-3 w-[15%]">Reference ID</th>
                <th class="px-3 py-3 w-[25%]">Debtor Entity</th>
                <th class="px-3 py-3 w-[18%]">Fee Configuration</th>
                <th class="px-3 py-3 w-[27%]">Lifecycle Audit Pipeline</th>
                <th class="px-3 py-3 text-right w-[15%]">Controls</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/60 text-xs text-slate-300">
              {invoicesList.map((invoice: any) => {
                const isEditing = editTargetId === invoice.id;
                const formId = `form-invoice-row-${invoice.id}`;

                return (
                  <tr class="hover:bg-slate-900/30 transition">
                    {isEditing && (
                      <form method="POST" id={formId}>
                        <input type="hidden" name="actionType" value="update" />
                        <input type="hidden" name="itemId" value={invoice.id} />
                      </form>
                    )}

                    <td class="px-3 py-3 font-mono font-bold text-brand-accent tracking-tight whitespace-normal break-all">
                      {invoice.invoice_number}
                    </td>
                    
                    <td class="px-3 py-3 whitespace-normal break-words">
                      <div class="font-bold text-white break-words">{invoice.company_name}</div>
                      <div class="text-[10px] text-slate-400 break-words mt-0.5 font-sans leading-relaxed" style="white-space: pre-line;">
                        {(() => {
                          if (invoice.item_description.startsWith('[')) {
                            try {
                              const parsed = JSON.parse(invoice.item_description);
                              return parsed.map((i: any) => `• ${i.description} (${i.type}): £${parseFloat(i.amount).toFixed(2)}`).join('\n');
                            } catch (e) {
                              return invoice.item_description;
                            }
                          }
                          return invoice.item_description;
                        })()}
                      </div>
                      {invoice.project_title && <div class="text-[9px] text-brand-accent/80 font-mono mt-0.5 break-words">Project: {invoice.project_title}</div>}
                    </td>

                    <td class="px-3 py-3 font-mono text-[11px] whitespace-normal break-words">
                      {isEditing ? (
                        <input type="number" name="amountDue" step="0.01" value={invoice.amount_due} form={formId} required class="w-full max-w-[90px] bg-brand-canvas border border-slate-800 rounded px-1.5 py-0.5 text-xs text-white" />
                      ) : (
                        <div class="space-y-0.5">
                          <div class="font-bold text-white">£{invoice.amount_due.toLocaleString('en-GB', {minimumFractionDigits:2})}</div>
                          <div class="text-[9px] text-slate-500 break-words">F: £{invoice.flat_fee_amount} | R: £{invoice.recurring_amount}</div>
                        </div>
                      )}
                    </td>

                    <td class="px-3 py-3 whitespace-normal break-words">
                      {isEditing ? (
                        <select name="status" form={formId} class="bg-brand-canvas border border-slate-800 rounded px-1.5 py-0.5 text-xs text-white w-full max-w-[120px]">
                          <option value="Generated" selected={invoice.status === 'Generated'}>Generated</option>
                          <option value="Sent" selected={invoice.status === 'Sent'}>Sent</option>
                          <option value="Paid" selected={invoice.status === 'Paid'}>Paid</option>
                        </select>
                      ) : (
                        <div class="space-y-1">
                          <div class="flex flex-wrap items-center gap-0.5 font-mono text-[8px] font-bold whitespace-normal">
                            {visualProgressionSteps.map((step) => {
                              const isCurrent = invoice.status === step.key;
                              return (
                                <span class={`px-1 py-0.5 rounded border transition-colors ${isCurrent ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-primary/10 text-brand-accent border-brand-primary/20'}`}>
                                  {step.label}
                                </span>
                              );
                            })}
                          </div>
                          <div class="text-[9px] font-mono text-slate-500 leading-none space-y-0.5 whitespace-normal break-words">
                            {invoice.sent_date && <div>• Sent: {invoice.sent_date}</div>}
                            {invoice.paid_date && <div>• Paid: <span class="text-emerald-400 font-bold">{invoice.paid_date}</span></div>}
                          </div>
                        </div>
                      )}
                    </td>

                    <td class="px-3 py-3 text-right font-mono text-[11px] whitespace-normal break-words">
                      {isEditing ? (
                        <div class="flex flex-col items-end gap-1">
                          <button type="submit" form={formId} class="text-emerald-400 font-bold hover:underline">Save</button>
                          <a href="?" class="text-slate-500 hover:underline">Cancel</a>
                        </div>
                      ) : viewMode === 'active' ? (
                        <div class="flex flex-col items-end gap-1">
                          <button 
                            type="button"
                            data-invoice-number={invoice.invoice_number}
                            data-company-name={invoice.company_name}
                            data-description={invoice.item_description}
                            data-amount={invoice.amount_due}
                            onclick="window.execute_inline_preview_call(this)"
                            class="text-emerald-400 hover:underline font-bold text-right"
                          >
                            Export
                          </button>
                          <a href={`?editId=${invoice.id}`} class="text-brand-accent hover:underline text-right">Edit</a>
                          <form method="POST" class="inline text-right">
                            <input type="hidden" name="actionType" value="archive" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-amber-500 hover:underline">Archive</button>
                          </form>
                        </div>
                      ) : (
                        <div class="flex flex-col items-end gap-1">
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="restore" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-emerald-400 hover:underline">Restore</button>
                          </form>
                          <form method="POST" class="inline" onsubmit="return confirm('Wipe element?');">
                            <input type="hidden" name="actionType" value="purge" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-rose-500 font-bold hover:underline">Purge</button>
                          </form>
                        </div>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <div id="previewModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/80 backdrop-blur-sm p-4 overflow-y-auto no-print">
    <div class="bg-brand-surface border border-slate-800 rounded-2xl max-w-4xl w-full p-6 shadow-2xl flex flex-col my-8 h-fit print-modal-box">
      
      <div class="flex justify-between items-center border-b border-slate-800 pb-3 mb-4 no-print">
        <h3 class="text-sm font-mono font-bold text-white uppercase tracking-wider">A4 Statement Print Engine Viewport</h3>
        <div class="flex items-center gap-3">
          <button type="button" onclick="window.print()" class="bg-brand-primary hover:bg-violet-600 text-white px-4 py-1.5 rounded-xl text-xs font-mono font-bold transition uppercase tracking-wider">Export As PDF</button>
          <button type="button" onclick="window.close_preview_modal()" class="text-slate-400 hover:text-white text-xs font-mono font-bold px-2 py-1 border border-slate-800 rounded-lg bg-brand-canvas">&times; Close</button>
        </div>
      </div>

      <div class="w-full flex justify-center bg-slate-900/40 p-4 rounded-xl border border-slate-800/60 overflow-x-auto no-print">
        <div class="bg-white text-slate-900 p-[21mm] box-border shadow-2xl rounded-sm w-[210mm] min-h-[297mm] flex flex-col justify-between" id="printArea">
          <div class="print-layout-target space-y-8 w-full bg-white text-slate-900">
            
            <div class="text-center space-y-3 border-b-2 border-slate-100 pb-6">
              <h2 class="text-2xl font-black tracking-tight text-slate-900 uppercase print-text-primary">JS Office Solutions</h2>
              <div class="flex justify-center">
                <img src="/jsos_logo.svg" alt="JS Office Solutions Logo" class="h-8 w-auto object-contain" />
              </div>
              <div class="text-[10px] font-mono text-slate-500 pt-1 flex justify-center gap-5 uppercase tracking-wider">
                <div><strong>Invoice Ref:</strong> <span id="modalInvoiceNumber" class="text-slate-900 font-bold"></span></div>
                <div><strong>Date Compiled:</strong> <span id="modalDateCompiled"></span></div>
              </div>
            </div>

            <div class="text-xl font-black text-slate-900 uppercase tracking-tight">Invoice Statement</div>

            <div class="grid grid-cols-2 gap-8 bg-slate-50 p-4 rounded-xl border border-slate-100">
              <div>
                <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-1">Debtor Entity</div>
                <div id="modalCompanyName" class="text-sm font-bold text-slate-800"></div>
              </div>
              <div class="text-right">
                <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-1">Initial payment due</div>
                <div id="modalPaymentDue" class="text-sm font-bold text-slate-900"></div>
              </div>
            </div>

            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                  <th class="p-3 font-bold text-slate-500 uppercase">Work Item Allocation Breakdown</th>
                  <th class="p-3 font-bold text-slate-500 uppercase text-right w-[140px]">Total Amount</th>
                </tr>
              </thead>
              <tbody id="modalItemsTableBody">
                </tbody>
            </table>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-slate-100">
              <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wide block">Payable Now</span>
                <div id="modalBreakdownPayableNow" class="text-base font-black text-slate-900 mt-1">£0.00</div>
              </div>
              <div class="bg-slate-50 p-3 rounded-xl border border-slate-100 text-right sm:text-left">
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wide block">Recurring Fee Schedule</span>
                <div id="modalBreakdownRecurring" class="text-base font-black text-brand-primary mt-1 print-text-primary">£0.00</div>
                <div id="modalSubscriptionNotice" class="hidden text-[9px] font-bold text-slate-500 mt-1 uppercase tracking-tight">
                  Fee must be paid on or before the 27th of every month until the subscription is cancelled.
                </div>
              </div>
            </div>

            <div class="flex flex-col items-end pt-4 pr-2">
              <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Total Combined Balance</div>
              <div id="modalTotalBalance" class="text-xl font-black text-slate-900 mt-0.5 print-text-primary"></div>
            </div>

          </div>

          <div class="pt-6 border-t border-slate-100 text-[9px] font-medium text-slate-400 text-center leading-relaxed w-full">
            Regulated under England & Wales Jurisdiction. Data Protection Officer Audit Verification: Joshua Stevens. UK GDPR Compliant Asset Ledger.
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script is:inline>
  window.stagedInvoiceItems = [];

  window.append_item_to_stack = function () {
    const descEl = document.getElementById('tempItemDescription');
    const typeEl = document.getElementById('tempItemType');
    const intervalEl = document.getElementById('tempItemInterval');
    const amountEl = document.getElementById('tempItemAmount');

    const descValue = descEl.value.trim();
    const typeValue = typeEl.value;
    const intervalValue = typeValue === 'Recurring Fee' ? intervalEl.value : null;
    const amountValue = parseFloat(amountEl.value || '0');

    if (!descValue || amountValue <= 0) {
      alert('Please specify a valid item description and monetary value.');
      return;
    }

    const itemNode = {
      id: Math.random().toString(36).substring(2, 11),
      description: descValue,
      type: typeValue,
      interval: intervalValue,
      amount: amountValue
    };

    window.stagedInvoiceItems.push(itemNode);
    window.synchronise_builder_state();

    descEl.value = '';
    amountEl.value = '';
  };

  window.remove_staged_node = function (nodeId) {
    window.stagedInvoiceItems = window.stagedInvoiceItems.filter(function (item) {
      return item.id !== nodeId;
    });
    window.synchronise_builder_state();
  };

  window.synchronise_builder_state = function () {
    const displayQueue = document.getElementById('stagedItemsManifestQueue');
    const serializedInput = document.getElementById('lineItemsSerializedInput');
    
    displayQueue.innerHTML = '';
    
    window.stagedInvoiceItems.forEach(function (item) {
      const container = document.createElement('div');
      container.className = 'flex justify-between items-center bg-brand-canvas p-2 rounded border border-slate-800 text-[11px]';
      
      const detailsSpan = document.createElement('span');
      detailsSpan.className = 'text-slate-300 truncate max-w-[170px]';
      detailsSpan.innerText = item.description + ' (' + (item.interval || 'Flat') + ': £' + item.amount.toFixed(2) + ')';
      
      const eraseButton = document.createElement('button');
      eraseButton.type = 'button';
      eraseButton.className = 'text-rose-400 hover:text-rose-300 font-bold font-mono px-1';
      eraseButton.innerHTML = '&times;';
      eraseButton.onclick = function () {
        window.remove_staged_node(item.id);
      };
      
      container.appendChild(detailsSpan);
      container.appendChild(eraseButton);
      displayQueue.appendChild(container);
    });

    serializedInput.value = JSON.stringify(window.stagedInvoiceItems);
  };

  window.execute_inline_preview_call = function (buttonElement) {
    const invoiceNumber = buttonElement.getAttribute('data-invoice-number');
    const companyName = buttonElement.getAttribute('data-company-name');
    const descriptionRaw = buttonElement.getAttribute('data-description');
    const amountDue = buttonElement.getAttribute('data-amount');
    
    window.trigger_preview_modal(invoiceNumber, companyName, descriptionRaw, amountDue);
  };

  window.trigger_preview_modal = function (invoiceNumber, companyName, itemDescription, amountDue) {
    document.getElementById('modalInvoiceNumber').innerText = invoiceNumber;
    document.getElementById('modalCompanyName').innerText = companyName;
    document.getElementById('modalDateCompiled').innerText = new Date().toLocaleDateString('en-GB');

    const executionDeadline = new Date();
    executionDeadline.setDate(executionDeadline.getDate() + 7);
    document.getElementById('modalPaymentDue').innerText = executionDeadline.toLocaleDateString('en-GB');

    const tableBody = document.getElementById('modalItemsTableBody');
    tableBody.innerHTML = '';

    let structuralItems = [];
    if (itemDescription.startsWith('[')) {
      try {
        structuralItems = JSON.parse(itemDescription);
      } catch (e) {
        structuralItems = [{ description: itemDescription, type: 'Flat Fee', amount: parseFloat(amountDue) }];
      }
    } else {
      const components = itemDescription.split(' | ');
      components.forEach(function (segment) {
        if (!segment.trim()) return;
        const matches = segment.match(/£([\d.]+)/);
        const derivedCost = matches ? parseFloat(matches[1]) : 0;
        const checkRecurring = segment.includes('Recurring');
        structuralItems.push({
          description: segment,
          type: checkRecurring ? 'Recurring Fee' : 'Flat Fee',
          interval: checkRecurring ? 'Monthly' : null,
          amount: derivedCost
        });
      });
    }

    let dynamicPayableNowTotal = 0;
    let dynamicRecurringMonthlyTotal = 0;
    let containsMonthlyRecurring = false;

    structuralItems.forEach(function (item) {
      const row = document.createElement('tr');
      row.className = 'border-b border-slate-100';

      const cellDescription = document.createElement('td');
      cellDescription.className = 'p-3 text-slate-700 font-medium whitespace-normal';
      
      if (item.type === 'Recurring Fee') {
        cellDescription.innerText = item.description + ' (Recurring Fee - ' + (item.interval || 'Monthly') + ')';
        dynamicRecurringMonthlyTotal += item.amount;
        if (item.interval === 'Monthly') {
          containsMonthlyRecurring = true;
        }
      } else {
        cellDescription.innerText = item.description + ' (Flat Fee)';
        dynamicPayableNowTotal += item.amount;
      }

      const cellCost = document.createElement('td');
      cellCost.className = 'p-3 text-right font-bold text-slate-900 w-[140px]';
      cellCost.innerText = '£' + item.amount.toLocaleString('en-GB', { minimumFractionDigits: 2 });

      row.appendChild(cellDescription);
      row.appendChild(cellCost);
      tableBody.appendChild(row);
    });

    document.getElementById('modalBreakdownPayableNow').innerText = '£' + dynamicPayableNowTotal.toLocaleString('en-GB', { minimumFractionDigits: 2 });
    document.getElementById('modalBreakdownRecurring').innerText = '£' + dynamicRecurringMonthlyTotal.toLocaleString('en-GB', { minimumFractionDigits: 2 });
    document.getElementById('modalTotalBalance').innerText = '£' + (dynamicPayableNowTotal + dynamicRecurringMonthlyTotal).toLocaleString('en-GB', { minimumFractionDigits: 2 });

    const subNotice = document.getElementById('modalSubscriptionNotice');
    if (containsMonthlyRecurring) {
      subNotice.classList.remove('hidden');
    } else {
      subNotice.classList.add('hidden');
    }

    document.getElementById('previewModal').classList.remove('hidden');
  };

  window.close_preview_modal = function () {
    document.getElementById('previewModal').classList.add('hidden');
  };
</script>
