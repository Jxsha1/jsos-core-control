<script is:inline>
  window.print_target_statement = function (invoiceNumber, companyName, itemDescription, amountDue) {
    const printWindow = window.open('', '_blank', 'width=850,height=1100');
    if (!printWindow) {
      alert('Popup blocker prevented invoice generation preview window from displaying.');
      return;
    }

    const compiledCost = parseFloat(amountDue).toLocaleString('en-GB', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });

    const cleanHtml = `
      <!DOCTYPE html>
      <html lang="en-GB">
      <head>
        <meta charset="UTF-8">
        <title>Invoice Statement - ${invoiceNumber}</title>
        <style>
          body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #0f172a; padding: 50px; line-height: 1.6; background-color: #ffffff; }
          .container { max-width: 750px; margin: 0 auto; }
          .header-row { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #f1f5f9; padding-bottom: 25px; margin-bottom: 40px; }
          .brand-title { font-size: 26px; font-weight: 800; color: #6d28d9; text-transform: uppercase; letter-spacing: -0.025em; }
          .brand-subtitle { font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 2px; }
          .meta-box { text-align: right; font-size: 13px; color: #475569; }
          .invoice-heading { font-size: 32px; font-weight: 900; color: #0f172a; margin-bottom: 30px; text-transform: uppercase; }
          .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 50px; }
          .section-caption { font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
          .entity-name { font-size: 16px; font-weight: 700; color: #1e293b; }
          .ledger-table { width: 100%; border-collapse: collapse; margin-bottom: 40px; text-align: left; }
          .ledger-table th { background-color: #f8fafc; padding: 14px 16px; font-size: 11px; font-weight: 700; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0; }
          .ledger-table td { padding: 16px; font-size: 14px; color: #334155; border-bottom: 1px solid #f1f5f9; }
          .summary-box { display: flex; flex-direction: column; align-items: flex-end; margin-top: 20px; padding-right: 16px; }
          .total-due-label { font-size: 13px; font-weight: 600; color: #64748b; text-transform: uppercase; }
          .total-due-value { font-size: 24px; font-weight: 800; color: #6d28d9; margin-top: 4px; }
          .legal-footer { margin-top: 100px; padding-top: 20px; border-top: 1px solid #e2e8f0; font-size: 10px; color: #94a3b8; text-align: center; font-weight: 500; }
          @print { body { padding: 20px; } }
        </style>
      </head>
      <body>
        <div class="container">
          <div class="header-row">
            <div>
              <div class="brand-title">JS Office Solutions</div>
              <div class="brand-subtitle">Automated Ledger Subsystem</div>
            </div>
            <div class="meta-box">
              <div><strong>Invoice Ref:</strong> ${invoiceNumber}</div>
              <div><strong>Date Compiled:</strong> ${new Date().toLocaleDateString('en-GB')}</div>
            </div>
          </div>
          
          <div class="invoice-heading">Invoice Statement</div>
          
          <div class="details-grid">
            <div>
              <div class="section-caption">Debtor Entity</div>
              <div class="entity-name">${companyName}</div>
            </div>
            <div style="text-align: right;">
              <div class="section-caption">Payment Terms</div>
              <div style="font-size: 14px; font-weight: 600; color: #334155;">14 Days Net</div>
            </div>
          </div>
          
          <table class="ledger-table">
            <thead>
              <tr>
                <th>Work Item Description</th>
                <th style="text-align: right; width: 150px;">Total Amount</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>${itemDescription}</td>
                <td style="text-align: right; font-weight: 700; color: #0f172a;">£${compiledCost}</td>
              </tr>
            </tbody>
          </table>
          
          <div class="summary-box">
            <div class="total-due-label">Total Balance Due</div>
            <div class="total-due-value">£${compiledCost}</div>
          </div>
          
          <div class="legal-footer">
            Regulated under England & Wales Jurisdiction. Data Protection Officer Audit Verification: Joshua Stevens. UK GDPR Compliant Asset Ledger.
          </div>
        </div>
        <script>
          window.onload = function() {
            window.print();
            setTimeout(function() { window.close(); }, 500);
          };
        </s` + `cript>
      </body>
      </html>
    `;

    printWindow.document.open();
    printWindow.document.write(cleanHtml);
    printWindow.document.close();
  };
</script>
