---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
const r2 = Astro.locals.runtime.env.INVOICE_VAULT;
let feedbackMessage = "";

const viewMode = Astro.url.searchParams.get('view') || 'active';
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create") {
      const clientId = formData.get("clientId");
      const prefix = formData.get("prefix"); // 'JLDS' or 'JJS'
      const description = formData.get("itemDescription");
      const costRaw = formData.get("itemCost");

      if (clientId && prefix && description && costRaw) {
        const cost = parseFloat(costRaw.toString());
        
        // 1. Fetch Target Profile Company Name for Abbreviation Calculation
        const client = await db.prepare("SELECT company_name FROM clients WHERE id = ?").bind(clientId).first();
        if (!client) throw new Error("Target profile object mismatch.");
        
        const name = client.company_name.trim();
        const words = name.split(/\s+/);
        let abbreviation = "";
        
        if (words.length === 1) {
          abbreviation = name.substring(0, 4).toUpperCase();
        } else {
          abbreviation = words.map((w: string) => w[0]).join("").toUpperCase();
        }

        // 2. Fetch Global Database Invoices Rows Count to Determine the Next Sequential ID
        const counterScan = await db.prepare("SELECT COUNT(*) as count FROM invoices").first();
        const nextSequenceId = (counterScan?.count || 0) + 1;

        // 3. Assemble the Automated Corporate Invoice Identifier Payload Name
        const generatedInvoiceNumber = `${prefix}-${abbreviation}-${nextSequenceId}`;

        const issuedStr = new Date().toISOString().split('T')[0];
        const due = new Date(); due.setDate(due.getDate() + 14);
        const dueStr = due.toISOString().split('T')[0];
        
        const invoiceId = crypto.randomUUID();
        const r2Key = `archives/${invoiceId}.json`;

        const payload = { id: invoiceId, invoiceNumber: generatedInvoiceNumber, clientId, total: cost, breakdown: description };
        await r2.put(r2Key, JSON.stringify(payload, null, 2), { contentType: 'application/json' });

        await db.prepare(`
          INSERT INTO invoices (id, client_id, invoice_number, amount_due, currency, status, issued_date, due_date, r2_archive_url, is_archived)
          VALUES (?, ?, ?, ?, 'GBP', 'Sent', ?, ?, ?, 0)
        `).bind(invoiceId, clientId, generatedInvoiceNumber, cost, issuedStr, dueStr, `/vault/${invoiceId}`).run();

        feedbackMessage = `Success: Compiled transaction reference name: ${generatedInvoiceNumber}`;
      }
    }

    if (action === "update") {
      const id = formData.get("itemId");
      const costRaw = formData.get("itemCost");
      const status = formData.get("status");

      await db.prepare(`
        UPDATE invoices SET amount_due = ?, status = ? WHERE id = ?
      `).bind(parseFloat(costRaw.toString()), status, id).run();
      feedbackMessage = "Success: Invoice data metrics modified inside ledger database.";
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 1 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Invoice row shifted to archived structures.";
    }

    if (action === "restore") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 0 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Invoice row restored to operational viewing scopes.";
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM invoices WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Financial data node fully executed and wiped.";
    }
  } catch (err: any) {
    feedbackMessage = `Financial Matrix Exception: ${err.message}`;
  }
}

let editingItem: any = null;
if (editTargetId) {
  editingItem = await db.prepare("SELECT * FROM invoices WHERE id = ?").bind(editTargetId).first();
}

const invoicesList = (await db.prepare(`
  SELECT i.*, c.company_name FROM invoices i 
  JOIN clients c ON i.client_id = c.id 
  WHERE i.is_archived = ? ORDER BY i.issued_date DESC
`).bind(viewMode === 'archived' ? 1 : 0).all()).results || [];

const clientsList = (await db.prepare("SELECT id, company_name FROM clients WHERE is_archived = 0 ORDER BY company_name ASC").all()).results || [];
---

<Layout title="Invoice Generator & Ledger Vault | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-6 md:p-12 space-y-10">
    
    <div class="flex justify-between items-end border-b border-slate-800 pb-6">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Automated Ledger</span>
        <h1 class="text-3xl font-extrabold text-white tracking-tight mt-1">Invoice Generation Hub</h1>
      </div>
      <div class="flex gap-2">
        <a href="?view=active" class={`px-4 py-2 rounded-xl text-xs font-bold border ${viewMode === 'active' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Active Ledger</a>
        <a href="?view=archived" class={`px-4 py-2 rounded-xl text-xs font-bold border ${viewMode === 'archived' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Archived Records</a>
      </div>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-2xl p-6 shadow-xl h-fit">
        <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider mb-4">{editingItem ? "Modify Ledger Entity" : "Compile Financial Ledger"}</h3>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="actionType" value={editingItem ? "update" : "create"} />
          {editingItem && <input type="hidden" name="itemId" value={editingItem.id} />}

          {!editingItem ? (
            <>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Profile Debtor *</label>
                <select name="clientId" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary">
                  <option value="">Select Target Account</option>
                  {clientsList.map((c: any) => <option value={c.id}>{c.company_name}</option>)}
                </select>
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Entity Identifier Prefix *</label>
                <div class="grid grid-cols-2 gap-2">
                  <label class="border border-slate-800 bg-brand-canvas p-2.5 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                    <span>JLDS</span> <input type="radio" name="prefix" value="JLDS" checked required class="accent-brand-accent" />
                  </label>
                  <label class="border border-slate-800 bg-brand-canvas p-2.5 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                    <span>JJS</span> <input type="radio" name="prefix" value="JJS" class="accent-brand-accent" />
                  </label>
                </div>
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Billable Item/Milestone Summary *</label>
                <input type="text" name="itemDescription" required placeholder="e.g. Fixed-Fee Out-of-Scope Server Array Migration" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
              </div>
            </>
          ) : (
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Collection Payment Status *</label>
              <select name="status" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary">
                <option value="Draft" selected={editingItem.status === "Draft"}>Draft Mode</option>
                <option value="Sent" selected={editingItem.status === "Sent"}>Sent / Outstanding</option>
                <option value="Paid" selected={editingItem.status === "Paid"}>Paid / Settled</option>
                <option value="Overdue" selected={editingItem.status === "Overdue"}>Overdue Ledger</option>
              </select>
            </div>
          )}

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Gross Net Capital Fee (£ GBP) *</label>
            <input type="number" name="itemCost" step="0.01" value={editingItem?.amount_due || ""} required placeholder="0.00" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>

          <button type="submit" class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-3 rounded-xl transition font-mono tracking-wide">
            {editingItem ? "Commit Balance Mod" : "Generate & Archive Invoice"}
          </button>
          {editingItem && <a href="?" class="block text-center text-[10px] text-slate-500 hover:text-slate-300 font-mono mt-2">&times; Cancel Selection</a>}
        </form>
      </div>

      <div class="lg:col-span-3">
        <div class="overflow-x-auto border border-slate-800 rounded-2xl bg-brand-surface/30 shadow-2xl">
          <table class="min-w-full divide-y divide-slate-800 text-left">
            <thead class="bg-brand-surface text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">
              <tr>
                <th class="px-6 py-4">Invoice Reference</th>
                <th class="px-6 py-4">Corporate Debtor Entity</th>
                <th class="px-6 py-4">Lifecycle Dates</th>
                <th class="px-6 py-4">Status Flag</th>
                <th class="px-6 py-4">Net Amount</th>
                <th class="px-6 py-4 text-right">Console Controls</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/60 text-xs text-slate-300">
              {invoicesList.length === 0 ? (
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-slate-500 font-mono">No transaction rows found within this scope matrix location.</td>
                </tr>
              ) : (
                invoicesList.map((invoice: any) => (
                  <tr class="hover:bg-slate-900/40 transition-colors duration-150">
                    <td class="px-6 py-4 font-mono font-bold text-brand-accent tracking-wide">{invoice.invoice_number}</td>
                    <td class="px-6 py-4 font-bold text-white">{invoice.company_name}</td>
                    <td class="px-6 py-4 font-mono text-[11px] text-slate-400">
                      <div>Issued: {new Date(invoice.issued_date).toLocaleDateString('en-GB')}</div>
                      <div class="text-slate-500 mt-0.5">Due parameter: {new Date(invoice.due_date).toLocaleDateString('en-GB')}</div>
                    </td>
                    <td class="px-6 py-4">
                      <span class={`text-[9px] font-mono font-bold px-2 py-0.5 rounded border ${invoice.status === 'Paid' ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' : 'bg-amber-500/10 border-amber-500/30 text-amber-400'}`}>
                        {invoice.status}
                      </span>
                    </td>
                    <td class="px-6 py-4 font-mono font-bold text-white">£{invoice.amount_due.toLocaleString('en-GB', { minimumFractionDigits: 2 })}</td>
                    <td class="px-6 py-4 text-right space-x-2 whitespace-nowrap font-mono text-[11px]">
                      {viewMode === 'active' ? (
                        <>
                          <a href={`?editId=${invoice.id}`} class="text-brand-accent hover:underline">Edit</a>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="archive" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-amber-500 hover:underline">Archive</button>
                          </form>
                        </>
                      ) : (
                        <>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="restore" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-emerald-400 hover:underline">Restore</button>
                          </form>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline" onsubmit="return confirm('CRITICAL RED ALERT: This action executes a final financial audit ledger destruction. Proceed?');">
                            <input type="hidden" name="actionType" value="purge" />
                            <input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-rose-500 hover:underline font-bold">Secure Purge</button>
                          </form>
                        </>
                      )}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</Layout>
