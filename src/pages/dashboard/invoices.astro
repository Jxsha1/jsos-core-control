---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
const r2 = Astro.locals.runtime.env.INVOICE_VAULT;
let feedbackMessage = "";

const viewMode = Astro.url.searchParams.get('view') || 'active';
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create") {
      const clientId = formData.get("clientId");
      const opportunityId = formData.get("opportunityId");
      const prefix = formData.get("prefix"); 
      const description = formData.get("itemDescription");
      
      const isFlatFee = formData.get("isFlatFee") === "1" ? 1 : 0;
      const flatFeeAmount = isFlatFee ? parseFloat(formData.get("flatFeeAmount")?.toString() || "0") : 0;
      const isRecurring = formData.get("isRecurring") === "1" ? 1 : 0;
      const recurringInterval = isRecurring ? formData.get("recurringInterval")?.toString() : null;
      const recurringAmount = isRecurring ? parseFloat(formData.get("recurringAmount")?.toString() || "0") : 0;
      const totalCombinedCost = flatFeeAmount + recurringAmount;

      if (clientId && prefix && description && totalCombinedCost > 0) {
        const client = await db.prepare("SELECT company_name FROM clients WHERE id = ?").bind(clientId).first();
        if (!client) throw new Error("Target account error.");
        
        const name = client.company_name.trim();
        const words = name.split(/\s+/);
        let abbreviation = (words.length === 1) ? name.substring(0, 4).toUpperCase() : words.map((w: string) => w[0]).join("").toUpperCase();

        const counterScan = await db.prepare("SELECT COUNT(*) as count FROM invoices").first();
        const nextSequenceId = (counterScan?.count || 0) + 1;
        const generatedInvoiceNumber = `${prefix}-${abbreviation}-${nextSequenceId}`;

        const issuedStr = new Date().toISOString().split('T')[0];
        const due = new Date(); due.setDate(due.getDate() + 14);
        const dueStr = due.toISOString().split('T')[0];
        
        await db.prepare(`
          INSERT INTO invoices (id, client_id, opportunity_id, invoice_number, item_description, is_flat_fee, flat_fee_amount, is_recurring, recurring_interval, recurring_amount, amount_due, status, issued_date, due_date, is_archived)
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'Generated', ?, ?, 0)
        `).bind(crypto.randomUUID(), clientId, opportunityId || null, generatedInvoiceNumber, description, isFlatFee, flatFeeAmount, isRecurring, recurringInterval, recurringAmount, totalCombinedCost, issuedStr, dueStr).run();

        if (opportunityId) {
          await db.prepare("UPDATE opportunities SET stage = 'Contract Won' WHERE id = ?").bind(opportunityId).run();
        }
        feedbackMessage = `Success: Invoice ${generatedInvoiceNumber} compiled.`;
      }
    }

    if (action === "update") {
      const id = formData.get("itemId");
      const nextStatus = formData.get("status");
      const cost = parseFloat(formData.get("amountDue")?.toString() || "0");

      const record = await db.prepare("SELECT status, sent_date, paid_date FROM invoices WHERE id = ?").bind(id).first();
      const currentTimestamp = new Date().toISOString().split('T')[0];
      
      let sentDate = record?.sent_date || null;
      let paidDate = record?.paid_date || null;

      if (nextStatus === "Sent" && record?.status !== "Sent") {
        sentDate = currentTimestamp;
      }
      if (nextStatus === "Paid" && record?.status !== "Paid") {
        if (!sentDate) sentDate = currentTimestamp;
        paidDate = currentTimestamp;
      }

      await db.prepare(`
        UPDATE invoices SET status = ?, amount_due = ?, sent_date = ?, paid_date = ? WHERE id = ?
      `).bind(nextStatus, cost, sentDate, paidDate, id).run();
      
      return Astro.redirect(`/dashboard/invoices?view=${viewMode}`);
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 1 WHERE id = ?").bind(id).run();
    }

    if (action === "restore") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE invoices SET is_archived = 0 WHERE id = ?").bind(id).run();
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM invoices WHERE id = ?").bind(id).run();
    }
  } catch (err: any) {
    feedbackMessage = `Exception Event: ${err.message}`;
  }
}

const invoicesList = (await db.prepare(`
  SELECT i.*, c.company_name, o.title as project_title FROM invoices i 
  JOIN clients c ON i.client_id = c.id 
  LEFT JOIN opportunities o ON i.opportunity_id = o.id
  WHERE i.is_archived = ? ORDER BY i.issued_date DESC
`).bind(viewMode === 'archived' ? 1 : 0).all()).results || [];

const clientsList = (await db.prepare("SELECT id, company_name FROM clients WHERE is_archived = 0 ORDER BY company_name ASC").all()).results || [];
const activeOpportunitiesList = (await db.prepare("SELECT id, title FROM opportunities WHERE is_archived = 0 AND stage != 'Contract Won'").all()).results || [];
const visualProgressionSteps = [{ key: 'Generated', label: 'Generated' }, { key: 'Sent', label: 'Sent' }, { key: 'Paid', label: 'Paid' }];
---

<Layout title="Invoice Generator & Vault Ledger | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-4 md:p-8 space-y-8 w-full box-border overflow-hidden no-print">
    
    <div class="flex justify-between items-end border-b border-slate-800 pb-4 flex-wrap gap-4">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Automated Ledger</span>
        <h1 class="text-2xl font-extrabold text-white tracking-tight mt-1">Invoice Generation Hub</h1>
      </div>
      <div class="flex gap-2 font-mono text-xs">
        <a href="?view=active" class={`px-3 py-1.5 rounded-lg border transition ${viewMode === 'active' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Active Scopes</a>
        <a href="?view=archived" class={`px-3 py-1.5 rounded-lg border transition ${viewMode === 'archived' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Archived Vault</a>
      </div>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 items-start w-full">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-xl p-5 shadow-xl space-y-4 w-full box-border">
        <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider">Compile Financial Ledger</h3>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="actionType" value="create" />
          
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Client *</label>
            <select name="clientId" required class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-2 text-xs text-white">
              <option value="">Select Account</option>
              {clientsList.map((c: any) => <option value={c.id}>{c.company_name}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Link to Sales Project</label>
            <select name="opportunityId" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-2 text-xs text-brand-accent font-mono">
              <option value="">Independent Milestone Item</option>
              {activeOpportunitiesList.map((o: any) => <option value={o.id}>{o.title}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Corporate Prefix Code *</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JLDS</span> <input type="radio" name="prefix" value="JLDS" checked required />
              </label>
              <label class="border border-slate-800 bg-brand-canvas p-2 rounded-xl flex items-center justify-between text-xs cursor-pointer">
                <span>JJS</span> <input type="radio" name="prefix" value="JJS" />
              </label>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Work Item Description *</label>
            <input type="text" name="itemDescription" required placeholder="Managed Platform Engineering" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-2 text-xs text-white" />
          </div>

          <div class="border border-slate-800 p-2.5 rounded-lg bg-brand-canvas/30 space-y-2">
            <div class="flex justify-between items-center text-[11px]">
              <span class="font-bold text-slate-400 uppercase">Include Flat Fee?</span>
              <div class="flex gap-2">
                <label><input type="radio" name="isFlatFee" value="1" checked onchange="document.getElementById('wrapperFlat').style.display='block'" /> Yes</label>
                <label><input type="radio" name="isFlatFee" value="0" onchange="document.getElementById('wrapperFlat').style.display='none'; document.getElementById('inputFlatPrice').value='0'" /> No</label>
              </div>
            </div>
            <div id="wrapperFlat"><input type="number" id="inputFlatPrice" name="flatFeeAmount" step="0.01" placeholder="Amount (£)" class="w-full bg-brand-canvas border border-slate-800 rounded px-2 py-1 text-xs text-white" /></div>
          </div>

          <div class="border border-slate-800 p-2.5 rounded-lg bg-brand-canvas/30 space-y-2">
            <div class="flex justify-between items-center text-[11px]">
              <span class="font-bold text-slate-400 uppercase">Include Recurring Fee?</span>
              <div class="flex gap-2">
                <label><input type="radio" name="isRecurring" value="1" onchange="document.getElementById('wrapperRec').style.display='block'" /> Yes</label>
                <label><input type="radio" name="isRecurring" value="0" checked onchange="document.getElementById('wrapperRec').style.display='none'; document.getElementById('inputRecPrice').value='0'" /> No</label>
              </div>
            </div>
            <div id="wrapperRec" class="space-y-1.5 hidden">
              <div class="grid grid-cols-3 gap-1 text-[9px] font-mono">
                <label class="border border-slate-800 p-1 rounded bg-brand-canvas flex items-center justify-between"><input type="radio" name="recurringInterval" value="Weekly" checked /> Wkly</label>
                <label class="border border-slate-800 p-1 rounded bg-brand-canvas flex items-center justify-between"><input type="radio" name="recurringInterval" value="Monthly" /> Mthly</label>
                <label class="border border-slate-800 p-1 rounded bg-brand-canvas flex items-center justify-between"><input type="radio" name="recurringInterval" value="Yearly" /> Yrly</label>
              </div>
              <input type="number" id="inputRecPrice" name="recurringAmount" step="0.01" placeholder="Amount (£)" class="w-full bg-brand-canvas border border-slate-800 rounded px-2 py-1 text-xs text-white" />
            </div>
          </div>

          <button type="submit" class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-2 rounded-lg transition font-mono uppercase tracking-wider">
            Execute Statement Log
          </button>
        </form>
      </div>

      <div class="xl:col-span-3 space-y-4 w-full overflow-hidden">
        <div class="overflow-x-auto border border-slate-800 rounded-xl bg-brand-surface/30 shadow-2xl w-full">
          <table class="w-full min-w-full divide-y divide-slate-800 text-left table-fixed">
            <thead class="bg-brand-surface text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">
              <tr>
                <th class="px-4 py-3 w-1/5">Reference ID</th>
                <th class="px-4 py-3 w-1/4">Debtor Entity</th>
                <th class="px-4 py-3 w-1/5">Fee Configuration</th>
                <th class="px-4 py-3 w-1/4">Lifecycle Audit Pipeline</th>
                <th class="px-4 py-3 text-right w-1/6">Controls</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/60 text-xs text-slate-300">
              {invoicesList.map((invoice: any) => {
                const isEditing = editTargetId === invoice.id;
                const formId = `form-invoice-row-${invoice.id}`;

                return (
                  <tr class="hover:bg-slate-900/30 transition">
                    {isEditing && (
                      <form method="POST" id={formId}>
                        <input type="hidden" name="actionType" value="update" />
                        <input type="hidden" name="itemId" value={invoice.id} />
                      </form>
                    )}

                    <td class="px-4 py-3 font-mono font-bold text-brand-accent tracking-wide truncate">{invoice.invoice_number}</td>
                    
                    <td class="px-4 py-3 truncate">
                      <div class="font-bold text-white truncate">{invoice.company_name}</div>
                      <div class="text-[10px] text-slate-400 truncate">{invoice.item_description}</div>
                    </td>

                    <td class="px-4 py-3 font-mono text-[11px] truncate">
                      {isEditing ? (
                        <input type="number" name="amountDue" step="0.01" value={invoice.amount_due} form={formId} required class="w-20 bg-brand-canvas border border-slate-800 rounded px-1.5 py-0.5 text-xs text-white" />
                      ) : (
                        <div>
                          <div class="font-bold text-white">£{invoice.amount_due.toLocaleString('en-GB', {minimumFractionDigits:2})}</div>
                          <div class="text-[9px] text-slate-500">F: £{invoice.flat_fee_amount} | R: £{invoice.recurring_amount}</div>
                        </div>
                      )}
                    </td>

                    <td class="px-4 py-3 whitespace-nowrap">
                      {isEditing ? (
                        <select name="status" form={formId} class="bg-brand-canvas border border-slate-800 rounded px-1.5 py-0.5 text-xs text-white w-full">
                          <option value="Generated" selected={invoice.status === 'Generated'}>Generated</option>
                          <option value="Sent" selected={invoice.status === 'Sent'}>Sent</option>
                          <option value="Paid" selected={invoice.status === 'Paid'}>Paid</option>
                        </select>
                      ) : (
                        <div class="space-y-1">
                          <div class="flex items-center gap-0.5 font-mono text-[8px] font-bold">
                            {visualProgressionSteps.map((step, idx) => {
                              const isCurrent = invoice.status === step.key;
                              const isPast = visualProgressionSteps.findIndex(s => s.key === invoice.status) >= idx;
                              return (
                                <>
                                  <span class={`px-1 py-0.5 rounded border ${isCurrent ? 'bg-brand-primary text-white border-brand-primary' : isPast ? 'bg-brand-primary/10 text-brand-accent border-brand-primary/20' : 'bg-slate-900 border-slate-800 text-slate-600'}`}>{step.label}</span>
                                  {idx < 2 && <span class="text-slate-800">&rarr;</span>}
                                </>
                              );
                            })}
                          </div>
                          <div class="text-[9px] font-mono text-slate-500 leading-none space-y-0.5">
                            {invoice.sent_date && <div>• Sent: {invoice.sent_date}</div>}
                            {invoice.paid_date && <div>• Paid: <span class="text-emerald-400 font-bold">{invoice.paid_date}</span></div>}
                          </div>
                        </div>
                      )}
                    </td>

                    <td class="px-4 py-3 text-right whitespace-nowrap font-mono text-[11px]">
                      {isEditing ? (
                        <div class="space-x-1">
                          <button type="submit" form={formId} class="text-emerald-400 font-bold hover:underline">Save</button>
                          <span class="text-slate-800">|</span>
                          <a href="?" class="text-slate-500 hover:underline">Cancel</a>
                        </div>
                      ) : viewMode === 'active' ? (
                        <div class="space-x-1">
                          <a href={`?editId=${invoice.id}`} class="text-brand-accent hover:underline">Edit</a>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="archive" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-amber-500 hover:underline">Archive</button>
                          </form>
                        </div>
                      ) : (
                        <div class="space-x-1">
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="restore" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-emerald-400 hover:underline">Restore</button>
                          </form>
                          <span class="text-slate-800">|</span>
                          <form method="POST" class="inline" onsubmit="return confirm('Wipe element?');">
                            <input type="hidden" name="actionType" value="purge" /><input type="hidden" name="itemId" value={invoice.id} />
                            <button type="submit" class="text-rose-500 font-bold hover:underline">Purge</button>
                          </form>
                        </div>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</Layout>
