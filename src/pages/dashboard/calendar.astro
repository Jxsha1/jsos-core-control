---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
let feedbackMessage = "";

const dateNow = new Date();
let currentYear = parseInt(Astro.url.searchParams.get('year') || "2026");
let currentMonth = parseInt(Astro.url.searchParams.get('month') || "6");
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create_block") {
      const datesStr = formData.get("targetDates");
      const startTime = formData.get("startTime");
      const endTime = formData.get("endTime");
      const subject = formData.get("subject") || "Administrative Focus Lockout";
      const blockStatus = formData.get("blockStatus") || "Blocked";

      if (datesStr && startTime && endTime) {
        const dates = datesStr.toString().split(",");
        for (const dateStr of dates) {
          if (!dateStr.trim()) continue;
          const startIso = new Date(`${dateStr}T${startTime}:00Z`).toISOString();
          const endIso = new Date(`${dateStr}T${endTime}:00Z`).toISOString();

          await db.prepare(`
            INSERT INTO bookings (id, client_name, client_email, meeting_subject, start_time, end_time, status, is_archived)
            VALUES (?, 'INTERNAL SYSTEM', 'ops@jsos.uk', ?, ?, ?, ?, 0)
          `).bind(crypto.randomUUID(), subject, startIso, endIso, blockStatus).run();
        }
        feedbackMessage = "Success: Operational matrix update committed live.";
      }
    }

    if (action === "update_status") {
      const id = formData.get("itemId");
      const nextStatus = formData.get("status");
      await db.prepare("UPDATE bookings SET status = ? WHERE id = ?").bind(nextStatus, id).run();
      feedbackMessage = "Success: Allocation state altered successfully.";
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE bookings SET is_archived = 1 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Allocation record archived.";
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM bookings WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Allocation record permanently purged.";
    }
  } catch (err: any) {
    feedbackMessage = `Scheduling Collision: ${err.message}`;
  }
}

let bookedMeetings = [];
try {
  bookedMeetings = (await db.prepare("SELECT * FROM bookings WHERE is_archived = 0 ORDER BY start_time ASC").all()).results || [];
} catch (e) {
  bookedMeetings = [];
}

const daysInMonth = new Date(currentYear, currentMonth, 0).getDate();
const firstDayIndex = new Date(currentYear, currentMonth - 1, 1).getDay();
const dayOffset = firstDayIndex === 0 ? 6 : firstDayIndex - 1;

const calendarGridDays = Array.from({ length: daysInMonth }, (_, i) => i + 1);
const paddingCells = Array.from({ length: dayOffset }, (_, i) => i);
const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
const currentMonthLabel = monthNames[currentMonth - 1];

const isPastLimit = currentYear === 2026 && currentMonth === 1;
const isFutureLimit = currentYear === 2027 && currentMonth === 6;

let prevMonth = currentMonth - 1;
let prevYear = currentYear;
if (prevMonth < 1) { prevMonth = 12; prevYear -= 1; }

let nextMonth = currentMonth + 1;
let nextYear = currentYear;
if (nextMonth > 12) { nextMonth = 1; nextYear += 1; }
---

<Layout title="Operational Master Calendar | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-4 md:p-6 space-y-6 w-full box-border overflow-hidden">
    
    <div class="flex justify-between items-center border-b border-slate-800 pb-4 flex-wrap gap-4">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Unified Operations Matrix</span>
        <h1 class="text-2xl font-extrabold text-white tracking-tight mt-1">Calendar Control</h1>
      </div>
      <a href="/book" target="_blank" class="bg-brand-primary hover:bg-violet-600 text-white px-4 py-2 rounded-xl text-xs font-semibold transition font-mono">
         Open Public Portal &rarr;
      </a>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 items-start w-full">
      
      <div class="xl:col-span-3 bg-brand-surface/60 border border-slate-800 rounded-xl p-5 shadow-xl w-full box-border">
        
        <div class="flex justify-between items-center mb-4 flex-wrap gap-2">
          <h2 class="text-base font-bold text-white font-mono uppercase tracking-wide">
             {currentMonthLabel} {currentYear}
          </h2>
          <div class="flex gap-1.5 font-mono text-xs">
            {isPastLimit ? (
              <span class="px-2.5 py-1 rounded bg-slate-900 text-slate-600 border border-slate-900 cursor-not-allowed">Prev</span>
            ) : (
              <a href={`?year=${prevYear}&month=${prevMonth}`} class="px-2.5 py-1 rounded bg-brand-canvas text-slate-300 border border-slate-800 hover:border-brand-primary transition">Prev</a>
            )}
            
            <a href="?year=2026&month=6" class="px-2.5 py-1 rounded bg-brand-canvas text-brand-accent border border-slate-800 hover:border-brand-primary transition">Current</a>
            
            {isFutureLimit ? (
              <span class="px-2.5 py-1 rounded bg-slate-900 text-slate-600 border border-slate-900 cursor-not-allowed">Next</span>
            ) : (
              <a href={`?year=${nextYear}&month=${nextMonth}`} class="px-2.5 py-1 rounded bg-brand-canvas text-slate-300 border border-slate-800 hover:border-brand-primary transition">Next</a>
            )}
          </div>
        </div>

        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider border-b border-slate-800/60 pb-2 mb-2">
          <div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div><div>Sun</div>
        </div>

        <div class="grid grid-cols-7 gap-1.5 w-full">
          {paddingCells.map(() => <div class="h-16 bg-slate-950/20 rounded-lg border border-transparent"></div>)}

          {calendarGridDays.map((day) => {
            const formattedDayStr = String(day).padStart(2, '0');
            const formattedMonthStr = String(currentMonth).padStart(2, '0');
            const loopDateIsoKey = `${currentYear}-${formattedMonthStr}-${formattedDayStr}`;
            
            const dayAllocations = bookedMeetings.filter((m: any) => m.start_time.startsWith(loopDateIsoKey));
            const hasMeetings = dayAllocations.some((m: any) => m.status === 'Scheduled');
            const hasBlockouts = dayAllocations.some((m: any) => m.status === 'Blocked' || m.status === 'Cancelled');
            return (
              <button 
                type="button"
                data-date-cell={loopDateIsoKey}
                onclick={`window.trigger_cell_allocation_drawer('${loopDateIsoKey}', '${day} {currentMonthLabel}', event)`}
                class={`h-16 rounded-xl border p-2 flex flex-col justify-between text-left transition relative overflow-hidden group w-full ${hasMeetings ? 'border-brand-primary bg-brand-primary/5 hover:bg-brand-primary/10' : hasBlockouts ? 'border-slate-800 bg-slate-900/20 opacity-60' : 'border-slate-800 bg-brand-canvas hover:border-slate-700'}`}
              >
                 <span class="text-xs font-mono font-bold text-slate-400 group-hover:text-white transition-colors">{day}</span>
                <div class="flex gap-1">
                  {hasMeetings && <span class="h-1.5 w-1.5 rounded-full bg-brand-accent animate-pulse"></span>}
                  {hasBlockouts && <span class="h-1.5 w-1.5 rounded-full bg-slate-600"></span>}
                </div>
               </button>
            )
          })}
        </div>
      </div>

      <div id="allocationDrawerControl" class="bg-brand-surface/80 border border-slate-800 rounded-xl p-5 shadow-xl space-y-4 w-full box-border">
        <div>
          <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider">Matrix Selection Controls</h3>
          <p class="text-[11px] text-slate-500 mt-0.5">Click calendar day cells to select multiple dates and stage actions.</p>
        </div>

        <div id="drawerSelectionPlaceholder" class="p-4 rounded-lg bg-brand-canvas/40 border border-dashed border-slate-800 text-slate-500 text-center text-xs font-mono">
          No target day node loaded.
        </div>

        <div id="drawerActionContainer" class="space-y-4 hidden w-full">
          <div class="p-2.5 rounded-lg bg-brand-canvas border border-slate-800 text-xs font-mono text-brand-accent flex justify-between items-center">
            <span>Staged:</span> <span id="displaySelectedTargetLabel" class="text-white font-bold"></span>
          </div>

          <form method="POST" class="space-y-3 border-t border-slate-800/60 pt-3">
            <input type="hidden" name="actionType" value="create_block" />
            <input type="hidden" id="submitTargetInputDate" name="targetDates" value="" />
            
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Start Time (GMT) *</label>
                <input type="time" name="startTime" required value="08:00" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">End Time (GMT) *</label>
                <input type="time" name="endTime" required value="18:00" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white" />
              </div>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Classification Class Type *</label>
              <select name="blockStatus" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white">
                <option value="Blocked">Enforce Blockout Time</option>
                <option value="Scheduled">Log Corporate Appointment</option>
               </select>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Subject Reference Note *</label>
              <input type="text" name="subject" required placeholder="e.g. Server Migration Focus Window" class="w-full bg-brand-canvas border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white" />
            </div>

            <div class="flex gap-2 pt-1">
              <button type="submit" class="flex-1 bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-2 rounded-lg transition font-mono uppercase tracking-wider">
                Enforce Action Link
              </button>
              <button type="button" onclick="window.clear_date_selection()" class="bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold text-xs px-3 py-2 rounded-lg transition font-mono uppercase tracking-wider">
                Clear
              </button>
            </div>
          </form>
        </div>
       </div>

    </div>

    <div class="space-y-3 w-full overflow-hidden pt-4">
      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider font-mono">Comprehensive Active Schedule Ledger</h3>
      <div class="border border-slate-800 rounded-xl bg-brand-surface/30 shadow-2xl w-full overflow-hidden">
        <table class="w-full min-w-full divide-y divide-slate-800 text-left table-fixed border-collapse">
          <thead class="bg-brand-surface text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">
            <tr>
              <th class="px-3 py-3 w-[20%]">Timestamp Date Frame</th>
              <th class="px-3 py-3 w-[25%]">Allocation Subject Context</th>
              <th class="px-3 py-3 w-[25%]">Target Participant Record</th>
              <th class="px-3 py-3 w-[15%]">State Class</th>
              <th class="px-3 py-3 text-right w-[15%]">Controls</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 text-xs text-slate-300">
            {bookedMeetings.length === 0 ? (
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-slate-500 font-mono">No tracking allocations logged across distributed storage instances.</td>
              </tr>
            ) : (
              bookedMeetings.map((meeting: any) => {
                const isItemEditing = editTargetId === meeting.id;
                const rowFormId = `form-meeting-row-${meeting.id}`;

                return (
                  <tr class="hover:bg-slate-900/30 transition">
                    {isItemEditing && (
                       <form method="POST" id={rowFormId}>
                        <input type="hidden" name="actionType" value="update_status" />
                        <input type="hidden" name="itemId" value={meeting.id} />
                       </form>
                     )}

                    <td class="px-3 py-3 font-mono text-[11px] whitespace-normal break-words">
                      <div class="font-bold text-white">{new Date(meeting.start_time).toLocaleDateString('en-GB')}</div>
                      <div class="text-brand-accent font-semibold mt-0.5">
                        {new Date(meeting.start_time).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'})} - {new Date(meeting.end_time).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'})} GMT
                      </div>
                     </td>

                    <td class="px-3 py-3 whitespace-normal break-words font-medium text-slate-200">
                      {meeting.meeting_subject}
                    </td>

                    <td class="px-3 py-3 font-mono text-[11px] whitespace-normal break-all text-slate-400">
                      <div>{meeting.client_name}</div>
                      <div class="text-slate-600 mt-0.5">{meeting.client_email}</div>
                    </td>

                    <td class="px-3 py-3 whitespace-normal break-words">
                       {isItemEditing ? (
                        <select name="status" form={rowFormId} class="bg-brand-canvas border border-slate-800 rounded px-1.5 py-0.5 text-xs text-white w-full max-w-[110px]">
                          <option value="Scheduled" selected={meeting.status === 'Scheduled'}>Scheduled</option>
                          <option value="Blocked" selected={meeting.status === 'Blocked'}>Blocked</option>
                          <option value="Cancelled" selected={meeting.status === 'Cancelled'}>Cancelled</option>
                          <option value="Completed" selected={meeting.status === 'Completed'}>Completed</option>
                        </select>
                       ) : (
                        <span class={`text-[9px] font-mono font-bold px-1.5 py-0.5 rounded border inline-block break-words ${meeting.status === 'Scheduled' ? 'bg-brand-primary/10 border-brand-primary/30 text-brand-accent' : 'bg-slate-800 border-slate-700 text-slate-400'}`}>
                          {meeting.status}
                        </span>
                     )}
                    </td>

                    <td class="px-3 py-3 text-right font-mono text-[11px] whitespace-normal break-words">
                      {isItemEditing ? (
                        <div class="flex flex-col items-end gap-1">
                          <button type="submit" form={rowFormId} class="text-emerald-400 font-bold hover:underline">Save</button>
                          <a href="?" class="text-slate-500 hover:underline">Cancel</a>
                        </div>
                      ) : (
                        <div class="flex flex-col items-end gap-1">
                          <a href={`?year=${currentYear}&month=${currentMonth}&editId=${meeting.id}`} class="text-brand-accent hover:underline">State</a>
                          <form method="POST" class="inline">
                            <input type="hidden" name="actionType" value="archive" /><input type="hidden" name="itemId" value={meeting.id} />
                            <button type="submit" class="text-amber-500 hover:underline">Archive</button>
                           </form>
                          <form method="POST" class="inline" onsubmit="return confirm('Purge row?');">
                            <input type="hidden" name="actionType" value="purge" /><input type="hidden" name="itemId" value={meeting.id} />
                            <button type="submit" class="text-rose-500 font-bold hover:underline">Purge</button>
                          </form>
                        </div>
                      )}
                     </td>
                  </tr>
                );
              })
            )}
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script is:inline>
    window.selectedDates = [];

    window.trigger_cell_allocation_drawer = function(isoDate, displayLabel, event) {
      const button = event.currentTarget;
      const index = window.selectedDates.indexOf(isoDate);

      if (index > -1) {
        window.selectedDates.splice(index, 1);
        button.classList.remove('border-brand-accent', 'bg-brand-primary/10', 'ring-1', 'ring-brand-accent');
      } else {
        window.selectedDates.push(isoDate);
        button.classList.add('border-brand-accent', 'bg-brand-primary/10', 'ring-1', 'ring-brand-accent');
      }

      const placeholder = document.getElementById('drawerSelectionPlaceholder');
      const actionContainer = document.getElementById('drawerActionContainer');

      if (window.selectedDates.length === 0) {
        placeholder.style.display = 'block';
        actionContainer.style.display = 'none';
        actionContainer.classList.add('hidden');
      } else {
        placeholder.style.display = 'none';
        actionContainer.style.display = 'block';
        actionContainer.classList.remove('hidden');
        
        window.selectedDates.sort();
        
        const displayContainer = document.getElementById('displaySelectedTargetLabel');
        if (window.selectedDates.length === 1) {
          displayContainer.innerText = displayLabel;
        } else {
          displayContainer.innerText = window.selectedDates.length + " Dates Selected";
        }
        
        document.getElementById('submitTargetInputDate').value = window.selectedDates.join(',');
      }
    };

    window.clear_date_selection = function() {
      window.selectedDates = [];
      document.querySelectorAll('[data-date-cell]').forEach(btn => {
        btn.classList.remove('border-brand-accent', 'bg-brand-primary/10', 'ring-1', 'ring-brand-accent');
      });
      document.getElementById('drawerSelectionPlaceholder').style.display = 'block';
      const actionContainer = document.getElementById('drawerActionContainer');
      actionContainer.style.display = 'none';
      actionContainer.classList.add('hidden');
      document.getElementById('submitTargetInputDate').value = '';
    };
  </script>
</Layout>
