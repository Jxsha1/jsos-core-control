---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
let bookedMeetings: any[] = [];
let calendarFeedback = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const dateStr = formData.get("blockDate"); 
    const timeStr = formData.get("blockTime"); 
    const description = formData.get("reason") || "Administrative Focus Period";

    if (dateStr && timeStr) {
      const startIso = new Date(`${dateStr}T${timeStr}:00Z`).toISOString();
      const endIso = new Date(new Date(startIso).getTime() + 30 * 60 * 1000).toISOString();

      await db.prepare(`
        INSERT INTO bookings (id, client_name, client_email, meeting_subject, start_time, end_time, status, uk_gdpr_consent_logged)
        VALUES (?, 'INTERNAL EXCLUSION', 'ops@jsos.uk', ?, ?, ?, 'Blocked', 0)
      `).bind(crypto.randomUUID(), description.toString(), startIso, endIso).run();

      calendarFeedback = "Success: Operational time frame locked out. Public booking link synchronized.";
    }
  } catch (err: any) {
    calendarFeedback = `Scheduling Collision: ${err.message}`;
  }
}

try {
  bookedMeetings = (await db.prepare("SELECT * FROM bookings WHERE status IN ('Scheduled', 'Blocked') ORDER BY start_time ASC").all()).results || [];
} catch (e) {
  bookedMeetings = [];
}

// Generate high-fidelity sample visual 31-day calendar node framework maps
const currentMonthDays = Array.from({ length: 31 }, (_, i) => i + 1);
---

<Layout title="Operational Master Calendar | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-6 md:p-12 space-y-10">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-800 pb-6 gap-4">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase">Unified Operations Matrix</span>
        <h1 class="text-3xl font-extrabold text-white tracking-tight mt-1">Calendar Control</h1>
      </div>
      <a href="/book" target="_blank" class="bg-brand-primary hover:bg-violet-600 text-white px-4 py-2 rounded-xl text-xs font-semibold transition">
        Launch Live Public Gateway &rarr;
      </a>
    </div>

    {calendarFeedback && (
      <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">
        {calendarFeedback}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="lg:col-span-2 space-y-4">
        <div class="bg-brand-surface/60 border border-slate-800 rounded-2xl p-6 shadow-xl">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-bold text-white uppercase tracking-wider">June 2026 Operational Matrix</h3>
            <span class="text-xs text-slate-400 font-medium">Standard Weekdays (08:00 - 18:00)</span>
          </div>
          
          <div class="grid grid-cols-7 gap-2 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider border-b border-slate-800/60 pb-2 mb-2">
            <div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div><div>Sun</div>
          </div>
          <div class="grid grid-cols-7 gap-2">
            {currentMonthDays.map((day) => {
              // Simple mockup layout engine attaching highlight indicators if matches active item dates
              const hasEvent = day === 8; 
              return (
                <div class={`h-16 rounded-xl border p-2 flex flex-col justify-between text-left transition cursor-pointer ${hasEvent ? 'border-brand-primary bg-brand-primary/10' : 'border-slate-800 bg-brand-canvas hover:border-slate-700'}`}>
                  <span class="text-xs font-mono font-bold text-slate-400">{day}</span>
                  {hasEvent && <span class="h-1.5 w-1.5 rounded-full bg-brand-accent animate-pulse"></span>}
                </div>
              )
            })}
          </div>
        </div>

        <div class="space-y-3 pt-4">
          <h3 class="text-sm font-bold text-slate-300 uppercase tracking-wider">Agenda Timeline</h3>
          {bookedMeetings.map((m) => (
            <div class={`p-4 rounded-xl border flex justify-between items-center ${m.status === 'Blocked' ? 'bg-brand-canvas/40 border-slate-900 opacity-60' : 'bg-brand-surface border-slate-800'}`}>
              <div>
                <span class={`text-[8px] font-mono font-bold px-1.5 py-0.5 rounded uppercase ${m.status === 'Blocked' ? 'bg-slate-800 text-slate-400' : 'bg-brand-accent/20 text-brand-accent'}`}>
                  {m.status}
                </span>
                <h4 class="text-sm font-bold text-white mt-1">{m.meeting_subject}</h4>
                <p class="text-xs text-slate-400">{m.client_name}</p>
              </div>
              <div class="text-right font-mono text-xs">
                <p class="text-white font-bold">{new Date(m.start_time).toLocaleDateString('en-GB')}</p>
                <p class="text-brand-accent font-semibold mt-0.5">{new Date(m.start_time).toLocaleTimeString('en-GB', {hour: '2-digit', minute:'2-digit'})} GMT</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-brand-surface/80 border border-slate-800 rounded-2xl p-6 shadow-xl h-fit">
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-2">Block Availability</h3>
        <p class="text-xs text-slate-400 mb-4">Instantly exclude custom intervals from the public client reservation engine interface.</p>
        <form method="POST" class="space-y-4">
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Exclusion Target Date *</label>
            <input type="date" name="blockDate" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Start Time Block (GMT) *</label>
            <input type="time" name="blockTime" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Lockout Rationale Note</label>
            <input type="text" name="reason" placeholder="e.g. Scheduled Network Core Maintenance" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <button type="submit" class="w-full bg-slate-950 border border-slate-800 text-slate-200 hover:border-brand-accent hover:text-white font-bold text-xs py-3 rounded-xl transition">
            Enforce Core Matrix Blockout
          </button>
        </form>
      </div>

    </div>
  </main>
</Layout>
