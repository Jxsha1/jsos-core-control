---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
let clientsList: any[] = [];
let feedbackMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const companyName = formData.get("companyName");
    const contactName = formData.get("contactName");
    const email = formData.get("email");
    const phone = formData.get("phone");
    const notes = formData.get("infrastructureNotes");
    const status = formData.get("status");

    if (companyName && contactName && email) {
      await db.prepare(`
        INSERT INTO clients (id, company_name, contact_name, email, phone, infrastructure_notes, status)
        VALUES (?, ?, ?, ?, ?, ?, ?)
      `).bind(crypto.randomUUID(), companyName, contactName, email, phone || null, notes || '', status).run();
      
      feedbackMessage = "Success: Corporate profile mapped into active directory.";
    }
  } catch (err: any) {
    feedbackMessage = `Directory Exclusion: ${err.message}`;
  }
}

try {
  clientsList = (await db.prepare("SELECT * FROM clients ORDER BY created_at DESC").all()).results || [];
} catch (e) {
  clientsList = [];
}
---

<Layout title="CRM Enterprise Directory | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-6 md:p-12 space-y-10">
    
    <div class="border-b border-slate-800 pb-6">
      <span class="text-xs font-bold text-brand-accent tracking-widest uppercase">Enterprise Context Management</span>
      <h1 class="text-3xl font-extrabold text-white tracking-tight mt-1">CRM Client Directory</h1>
    </div>

    {feedbackMessage && (
      <div class="p-4 bg-brand-surface border border-emerald-500/30 rounded-xl text-xs text-emerald-400 font-mono">
        {feedbackMessage}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-2xl p-6 shadow-xl h-fit">
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Register Account</h3>
        <form method="POST" class="space-y-4">
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Company Entity Name *</label>
            <input type="text" name="companyName" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Primary Contact Name *</label>
            <input type="text" name="contactName" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Business Email Address *</label>
            <input type="email" name="email" required class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Direct Phone Link</label>
            <input type="text" name="phone" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Operational Lifecycle Status *</label>
            <select name="status" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary">
              <option value="New Prospect">New Prospect</option>
              <option value="Strategic Negotiation">Strategic Negotiation</option>
              <option value="Active Managed Client">Active Managed Client</option>
            </select>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Infrastructure Profile Notes</label>
            <textarea name="infrastructureNotes" rows="3" class="w-full bg-brand-canvas border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-brand-primary resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-brand-primary hover:bg-violet-600 text-white font-bold text-xs py-3 rounded-xl transition">
            Map Client Profile
          </button>
        </form>
      </div>

      <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-4 h-fit">
        {clientsList.map(c => (
          <div class="bg-brand-surface/90 border border-slate-800 rounded-xl p-5 space-y-3 relative overflow-hidden group hover:border-brand-primary/60 transition">
            <div class="flex justify-between items-start">
              <div>
                <h4 class="text-base font-bold text-white">{c.company_name}</h4>
                <p class="text-xs text-slate-400">Rep: {c.contact_name}</p>
              </div>
              <span class={`text-[9px] font-bold font-mono px-2 py-0.5 rounded border ${c.status === 'Active Managed Client' ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' : 'bg-amber-500/10 border-amber-500/30 text-amber-400'}`}>
                {c.status.replace(/_/g, ' ')}
              </span>
            </div>
            <div class="text-xs space-y-1 text-slate-300 pt-2 border-t border-slate-900 font-mono">
              <p><span class="text-slate-500">Email:</span> {c.email}</p>
              {c.phone && <p><span class="text-slate-500">Phone:</span> {c.phone}</p>}
            </div>
            {c.infrastructure_notes && (
              <div class="bg-brand-canvas/60 p-2 rounded-lg border border-slate-900 text-[11px] text-slate-400">
                {c.infrastructure_notes}
              </div>
            )}
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>
