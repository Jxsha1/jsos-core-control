---
import Layout from '../../layouts/Layout.astro';

const db = Astro.locals.runtime.env.DB;
let feedbackMessage = "";

const activeFilter = Astro.url.searchParams.get('statusFilter') || 'All';
const viewMode = Astro.url.searchParams.get('view') || 'active';
const editTargetId = Astro.url.searchParams.get('editId') || null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("actionType");

    if (action === "create") {
      const company = formData.get("companyName");
      const contact = formData.get("contactName");
      const email = formData.get("email");
      const phone = formData.get("phone");
      const notes = formData.get("notes");
      const status = formData.get("status");

      await db.prepare(`
        INSERT INTO clients (id, company_name, contact_name, email, phone, infrastructure_notes, status, is_archived)
        VALUES (?, ?, ?, ?, ?, ?, ?, 0)
      `).bind(crypto.randomUUID(), company, contact, email, phone, notes, status).run();
      feedbackMessage = "Success: Account record logged into directory.";
    }

    if (action === "update") {
      const id = formData.get("itemId");
      const company = formData.get("companyName");
      const contact = formData.get("contactName");
      const email = formData.get("email");
      const phone = formData.get("phone");
      const notes = formData.get("notes");
      const status = formData.get("status");

      await db.prepare(`
        UPDATE clients SET company_name = ?, contact_name = ?, email = ?, phone = ?, infrastructure_notes = ?, status = ? WHERE id = ?
      `).bind(company, contact, email, phone, notes, status, id).run();
      feedbackMessage = "Success: Changes committed inline.";
      return Astro.redirect(`/dashboard/clients?view=${viewMode}&statusFilter=${activeFilter}`);
    }

    if (action === "archive") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE clients SET is_archived = 1 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Record shifted to archive container.";
    }

    if (action === "restore") {
      const id = formData.get("itemId");
      await db.prepare("UPDATE clients SET is_archived = 0 WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Record returned to active view.";
    }

    if (action === "purge") {
      const id = formData.get("itemId");
      await db.prepare("DELETE FROM clients WHERE id = ?").bind(id).run();
      feedbackMessage = "Success: Data node completely destroyed from edge hardware.";
    }
  } catch (err: any) {
    feedbackMessage = `Operational Alert: ${err.message}`;
  }
}

let baseQuery = "SELECT * FROM clients WHERE is_archived = ?";
const queryParams: any[] = [viewMode === 'archived' ? 1 : 0];

if (activeFilter !== 'All') {
  baseQuery += " AND status = ?";
  queryParams.push(activeFilter);
}
baseQuery += " ORDER BY company_name ASC";

const clientsList = (await db.prepare(baseQuery).bind(...queryParams).all()).results || [];
---

<Layout title="CRM Enterprise Directory | JSOS Core Control">
  <main class="max-w-7xl mx-auto p-4 md:p-8 space-y-6 w-full box-border overflow-hidden">
    
    <div class="flex justify-between items-end border-b border-slate-800 pb-4 flex-wrap gap-4">
      <div>
        <span class="text-xs font-bold text-brand-accent tracking-widest uppercase font-mono">Enterprise Workspace</span>
        <h1 class="text-2xl font-extrabold text-white tracking-tight mt-1">CRM Client Directory</h1>
      </div>
      <div class="flex gap-2 font-mono text-xs">
        <a href="?view=active" class={`px-3 py-1.5 rounded-lg border font-bold transition ${viewMode === 'active' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Active</a>
        <a href="?view=archived" class={`px-3 py-1.5 rounded-lg border font-bold transition ${viewMode === 'archived' ? 'bg-brand-primary text-white border-brand-primary' : 'bg-brand-surface text-slate-400 border-slate-800'}`}>Archived</a>
      </div>
    </div>

    {feedbackMessage && <div class="p-4 bg-brand-surface border border-brand-primary/30 rounded-xl text-xs font-mono text-brand-accent">{feedbackMessage}</div>}

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 items-start w-full">
      
      <div class="bg-brand-surface/80 border border-slate-800 rounded-xl p-5 shadow-xl h-fit w-full box-border">
        <h3 class="text-xs font-bold text-slate-300 uppercase tracking-wider mb-3">Onboard Corporate Profile</h3>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="actionType" value="create" />
