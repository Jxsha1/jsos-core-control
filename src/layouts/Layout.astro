---
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
  hideNav?: boolean; // Controls navigation visibility for client-facing or public screens
}
const { title = "JSOS Core Control", hideNav = false } = Astro.props;
---
<!doctype html>
<html lang="en-GB" class="bg-brand-canvas text-slate-100 antialiased selection:bg-brand-accent/30">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/jsos_logo.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen font-sans flex flex-col">
    { !hideNav && <Navigation /> }
    <div class="flex-1 w-full">
      <slot />
    </div>
  </body>
</html>
