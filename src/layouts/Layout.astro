---
interface Props {
  title?: string;
}
const { title = "JSOS Core Control" } = Astro.props;
---
<!doctype html>
<html lang="en-GB" class="bg-brand-canvas text-slate-100 antialiased selection:bg-brand-accent/30">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen font-sans">
    <slot />
  </body>
</html>
