{
  "name": "jsos-core-control",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-06-03",
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "ENTER_YOUR_KV_NAMESPACE_ID"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jsos-core-db",
      "database_id": "ENTER_YOUR_D1_DATABASE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "INVOICE_VAULT",
      "bucket_name": "jsos-invoice-vault"
    }
  ]
}
