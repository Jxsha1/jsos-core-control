{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jsos-core-control",
  "main": "./dist/_worker.js",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
